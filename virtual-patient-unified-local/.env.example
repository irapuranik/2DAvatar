# OpenAI + ElevenLabs (required for LLM / TTS)
OPENAI_API_KEY=
ELEVEN_LABS_API_KEY=

# Local JWT signing secret — change for anything beyond your laptop
JWT_SECRET=

# Optional: seed an admin on first startup (bcrypt-hashed password stored in SQLite)
SEED_ADMIN_EMAIL=admin@local.test
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_DISPLAY_NAME=Admin

# Optional: promote this email to admin on register
ADMIN_EMAIL=

# SQLite database file (default: backend/aimii.db)
# DATABASE_URL=sqlite:////absolute/path/to/aimii.db

# Viseme image generation backend:
# - local: no cloud credits, runs on this machine
# - hf: Hugging Face router/providers
VISEME_IMAGE_BACKEND=local

# Local diffusion defaults (Apple Silicon friendly)
# LOCAL_TXT2IMG_MODEL=runwayml/stable-diffusion-v1-5
# LOCAL_IMG2IMG_MODEL=runwayml/stable-diffusion-v1-5
# LOCAL_TXT2IMG_WIDTH=512
# LOCAL_TXT2IMG_HEIGHT=512
# LOCAL_TXT2IMG_STEPS=30
# LOCAL_TXT2IMG_GUIDANCE_SCALE=7.5
# LOCAL_IMG2IMG_STEPS=35
# LOCAL_IMG2IMG_GUIDANCE_SCALE=8.0
# LOCAL_IMG2IMG_STRENGTH=0.62
# CUSTOM_LOCAL_MAX_RETRIES=2
# CUSTOM_LOCAL_RETRY_STRENGTH_STEP=0.08
# CUSTOM_LOCAL_RETRY_GUIDANCE_STEP=0.5
# CUSTOM_LOCAL_IDENTITY_THRESHOLD=0.84
# CUSTOM_LOCAL_BACKGROUND_THRESHOLD=0.85
# CUSTOM_LOCAL_MOUTH_DELTA_THRESHOLD=0.055
# CUSTOM_LOCAL_BLINK_EYE_DELTA_THRESHOLD=0.035
# CUSTOM_LOCAL_X_MOUTH_MAX_DELTA=0.08
# CUSTOM_LOCAL_LORA_DIR=
# CUSTOM_LOCAL_LORA_SCALE=0.8

# Hugging Face router/providers (cloud FLUX.2 pipeline).
# Fine-grained token: enable "Make calls to Inference Providers" (Hub -> Settings -> Access Tokens).
# HUGGINGFACE_API_TOKEN=hf_...
#
# Stage 1: text-to-image for A.png
# HF_FLUX2_TXT2IMG_PROVIDER=hf-inference
# HF_FLUX2_TXT2IMG_PROVIDER_FALLBACKS=replicate
# HF_FLUX2_TXT2IMG_MODEL=black-forest-labs/FLUX.1-schnell
# HF_FLUX2_TXT2IMG_MODEL_FALLBACKS=
# HF_FLUX2_TXT2IMG_WIDTH=512
# HF_FLUX2_TXT2IMG_HEIGHT=512
# HF_FLUX2_TXT2IMG_STEPS=4
# HF_FLUX2_TXT2IMG_GUIDANCE_SCALE=7.5
#
# Stage 2: image-to-image for B-H, X, blink from A.png
# HF_FLUX2_IMG2IMG_PROVIDER=hf-inference
# HF_FLUX2_IMG2IMG_PROVIDER_FALLBACKS=replicate
# HF_FLUX2_IMG2IMG_MODEL=black-forest-labs/FLUX.2-klein-4B
# HF_FLUX2_IMG2IMG_MODEL_FALLBACKS=black-forest-labs/FLUX.2-dev
# HF_IMG2IMG_STRENGTH=0.30
# HF_IMG2IMG_GUIDANCE_SCALE=7.5
# HF_IMG2IMG_STEPS=4
#
# Retry and pacing
# HF_INFERENCE_TIMEOUT_S=300
# HF_REQUEST_DELAY_S=2.0
# HF_MAX_RETRIES=3
# HF_RETRY_BACKOFF_S=8.0

# Gemini image generation (Nano Banana capability via Gemini API)
# Set VISEME_IMAGE_BACKEND=gemini to use this path.
# GEMINI_API_KEY=AIza...
# Alternatively:
# NANOBANANA_API_KEY=AIza...
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
# GEMINI_IMAGE_WIDTH=512
# GEMINI_IMAGE_HEIGHT=512
# GEMINI_REQUEST_DELAY_S=1.0
# GEMINI_MAX_RETRIES=3
# GEMINI_RETRY_BACKOFF_S=5.0

# Rhubarb lip-sync binary (install separately — see README)
# Rhubarb binary (defaults in config.py if unset)
# RHUBARB_PATH=/opt/homebrew/bin/rhubarb

# Frontend (Vite) — optional; defaults suit local dev
# VITE_API_URL=   leave empty to use Vite proxy to the API

# Latency tuning (optional)
# OPENAI_MODEL=gpt-4o-mini        # default; use gpt-4o for max quality (slower)
# LLM_HISTORY_MAX_MESSAGES=12
# LLM_MAX_TOKENS=80
# LLM_TEMPERATURE=0.45
# GLOBAL_PROMPT_MAX_CHARS=0     # cap global prompt length; 0 = unlimited
# ELEVEN_LABS_OUTPUT_FORMAT=mp3_22050_32
